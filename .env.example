# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# Groq (OpenAI-compatible). Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# LLM backend: groq | ollama. Tools that generate text (e.g. golden_gen_diy)
# default to this; override per-run with --provider.
LLM_PROVIDER=groq
# Local Ollama (OpenAI-compatible endpoint). Used when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Embedding model (local)
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# Paths
PDF_DIR=pdfs
# Optional — metadata.json produced by extract.py (titles, abstracts).
# Leave it as-is if you don't have one; ingestion still works without it.
METADATA_PATH=metadata.json
GOLDEN_PATH=src/rag/golden/golden.jsonl

# Chunking
# CHUNK_STRATEGY: section | recursive | unstructured
#   section      = TOC-aware section chunking (PyMuPDF)
#   recursive    = flat text + recursive token splitter (PyMuPDF)
#   unstructured = layout/table-aware parse; tables are isolated into their own
#                  chunks. Needs `pip install 'unstructured[pdf]'`. The hi_res
#                  strategy (for tables) also requires system binaries:
#                  `sudo apt install poppler-utils tesseract-ocr`.
CHUNK_STRATEGY=section
CHUNK_TOKENS=800
CHUNK_OVERLAP=100
# Only used when CHUNK_STRATEGY=unstructured:
UNSTRUCTURED_STRATEGY=hi_res
UNSTRUCTURED_INFER_TABLES=true

# Retrieval
TOP_K=10
RRF_K=60
